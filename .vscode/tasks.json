{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Dev Server and Open Browser",
      "type": "shell",
      "command": "npm.cmd",
      "args": [
        "run",
        "dev:open"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*VITE.*",
          "endsPattern": ".*Local:.*http://127\\.0\\.0\\.1:5173/.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      }
    }
  ]
}
